NODE_ENV=development
PORT=3001

# Neon Postgres (usa la pooled connection string)
# Ejemplo: postgresql://user:pass@ep-xxxx-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
PGSSL=require

PGPOOL_MIN=0
PGPOOL_MAX=10
PGPOOL_IDLE_MS=10000

# Seguridad (obligatorio en producción)
JWT_SECRET=REEMPLAZA_ESTE_VALOR_POR_UN_SECRETO_LARGO_Y_UNICO

# Opcional para mensajes/compatibilidad existente
BANANO_WA=584129326373
